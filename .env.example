# Cuentitas Bot — Variables de entorno
# Copiá este archivo como .env y completá tus datos:  cp .env.example .env
# NUNCA subas el archivo .env a GitHub.

# ── API de Cuentitas (superficie solo-bot) ───────────────────
# URL base de la API y la clave única del bot (debe coincidir con BOT_API_KEY del
# .env de Cuentitas en la VPS). El bot manda el teléfono; Cuentitas resuelve el usuario.
CUENTITAS_API_URL=https://cuentitas.site/api
BOT_API_KEY=

# ── Base de datos (sólo historial de chat) ───────────────────
# Local (sin instalar nada): sqlite+aiosqlite:///./cuentitasbot.db
# VPS (docker-compose): postgresql://USER:PASS@agent-postgres:5432/agent_db
DATABASE_URL=sqlite+aiosqlite:///./cuentitasbot.db

# ── Postgres + red de OpenWA (sólo para el deploy con docker-compose) ──
POSTGRES_USER=cuentitasbot
POSTGRES_PASSWORD=cambiame-en-el-vps
# Nombre de la red que crea el compose de OpenWA (verificar con `docker network ls`).
OPENWA_NETWORK=openwa-network

# ── Modelo (cualquier API compatible con OpenAI: OpenRouter, Ollama...) ──
# DEBE soportar tool calling. Reusá la misma config que Rimainder.
OLLAMA_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_MODEL=openai/gpt-4o-mini
OLLAMA_MAX_TOKENS=600
LLM_API_KEY=sk-or-v1-...        # tu key de openrouter.ai/keys

# ── Identidad del agente ──────────────────────────────────────
AGENT_NAME=Cuentitas
TIMEZONE=America/Argentina/Buenos_Aires

# ── OpenWA (gateway de WhatsApp) — se usa en el deploy (requiere chip) ──
WHATSAPP_PROVIDER=openwa
OPENWA_URL=http://openwa-api:2785
OPENWA_API_KEY=
OPENWA_SESSION_ID=
WEBHOOK_SECRET=
WEBHOOK_SIGNATURE_HEADER=x-openwa-signature

# ── Servidor ──────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development
